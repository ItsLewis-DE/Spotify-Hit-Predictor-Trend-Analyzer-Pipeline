# =============================================================================
# Airflow Docker Compose - Environment Variables
# =============================================================================
# Copy this file to .env and update the values for your environment.
# IMPORTANT: Never commit the .env file to version control!
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow

# --- Airflow Core ---
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=your_fernet_key_here

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
AIRFLOW_WEBSERVER_SECRET_KEY=your_webserver_secret_key_here

# --- Airflow UID (run `id -u` to get your user ID) ---
AIRFLOW_UID=50000

# --- Airflow Webserver ---
AIRFLOW_WEBSERVER_PORT=8080

# --- Airflow Admin User ---
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow

# --- Project directory (default: current directory) ---
# AIRFLOW_PROJ_DIR=.

# --- Spotify API ---
# Get these from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# --- AWS S3 ---
# Required for uploading crawled CSV files to S3
# Get these from AWS IAM Console
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_REGION=ap-southeast-1
S3_BUCKET_NAME=your_s3_bucket_name_here

# --- RapidAPI ---
# Get these from RapidAPI Spotify Extended Audio Features API
X-RapidAPI-Key-1=your_rapidapi_key_1_here
X-RapidAPI-Key-2=your_rapidapi_key_2_here
X-RapidAPI-Key-3=your_rapidapi_key_3_here
X-RapidAPI-Key-4=your_rapidapi_key_4_here
